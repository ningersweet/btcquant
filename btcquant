# Docker命令
cmd_docker() {
    local action=$1
    local service=$2
    
    case $action in
        build)
            docker_build $service
            ;;
        up)
            docker_up $service
            ;;
        down)
            docker_down $service
            ;;
        ps)
            docker_ps
            ;;
        logs)
            docker_logs $service
            ;;
        monitor)
            docker_monitor
            ;;
        *)
            print_error "未知Docker命令: $action"
            exit 1
            ;;
    esac
}

# 构建Docker镜像
docker_build() {
    local service=$1
    print_header "构建Docker镜像"
    if [ -z "$service" ]; then
        docker-compose build
    else
        docker-compose build $service
    fi
    print_success "构建完成"
}

# 启动容器
docker_up() {
    local service=$1
    print_header "启动容器"
    if [ -z "$service" ]; then
        docker-compose up -d
    else
        docker-compose up -d $service
    fi
    print_success "容器已启动"
}

# 停止容器
docker_down() {
    local service=$1
    print_header "停止容器"
    if [ -z "$service" ]; then
        docker-compose down
    else
        docker-compose stop $service
    fi
    print_success "容器已停止"
}

# 查看容器状态
docker_ps() {
    print_header "容器状态"
    docker-compose ps
}

# 查看容器日志
docker_logs() {
    local service=${1:-data-service}
    print_info "查看 $service 日志..."
    docker-compose logs --tail 50 -f $service
}

# 监控容器资源
docker_monitor() {
    print_header "容器资源监控"
    if [ -f "$SCRIPT_DIR/monitor_container.sh" ]; then
        "$SCRIPT_DIR/monitor_container.sh"
    else
        docker stats
    fi
}

# 训练管理命令
cmd_train() {
    local action=$1
    shift
    
    case $action in
        start)
            train_start "$@"
            ;;
        status)
            train_status
            ;;
        logs)
            train_logs
            ;;
        stop)
            train_stop
            ;;
        sync-data)
            train_sync_data
            ;;
        sync-model)
            train_sync_model "$@"
            ;;
        sync-config)
            train_sync_config
            ;;
        *)
            print_error "未知训练命令: $action"
            exit 1
            ;;
    esac
}

# 启动训练
train_start() {
    local use_gpu=false
    
    # 解析参数
    while [[ $# -gt 0 ]]; do
        case $1 in
            --gpu)
                use_gpu=true
                shift
                ;;
            *)
                shift
                ;;
        esac
    done
    
    if [ "$use_gpu" = true ]; then
        print_header "启动GPU训练"
        
        # 检查本地配置文件
        if [ ! -f "config.yaml" ]; then
            print_error "配置文件不存在: config.yaml"
            print_info "请先复制并配置: cp config.yaml.example config.yaml"
            return 1
        fi
        
        # 传输配置文件到GPU服务器
        print_info "传输配置文件到GPU服务器..."
        scp config.yaml $GPU_SERVER:~/workspace/btcquant/
        
        print_info "提示: 邮件通知配置在 config.yaml 的 notification.email 部分"
        
        # 在GPU服务器上启动训练
        ssh $GPU_SERVER << 'EOF'
set -e
cd ~/workspace/btcquant

# 激活venv环境
source venv/bin/activate

# 检查是否有正在运行的训练任务
if [ -f ~/training.pid ]; then
    PID=$(cat ~/training.pid)
    if ps -p $PID > /dev/null 2>&1; then
        echo "发现正在运行的训练任务 (PID: $PID)"
        read -p "是否停止并启动新训练? (y/n) " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            echo "停止旧训练任务..."
            kill $PID
            sleep 2
        else
            echo "取消启动新训练"
            exit 1
        fi
    fi
    rm -f ~/training.pid
fi

# 创建存储目录
mkdir -p storage/logs storage/cache storage/models

# 启动后台训练
cd predict/training
nohup python train_with_notification.py --mode cache > ../../storage/logs/training.log 2>&1 &
PID=$!
echo $PID > ~/training.pid

echo "✓ 训练已在后台启动"
echo "  PID: $PID"
echo "  日志: ~/workspace/btcquant/storage/logs/training.log"
echo ""
echo "查看实时日志:"
echo "  tail -f ~/workspace/btcquant/storage/logs/training.log"
echo ""
echo "训练完成后会自动传输模型并发送邮件通知"
EOF
        
        print_success "GPU训练已启动"
        print_info "使用 'btcquant train logs' 查看日志"
        print_info "使用 'btcquant train status' 查看状态"
    else
        print_header "启动本地训练"
        cd "$SCRIPT_DIR/predict/training"
        python train.py
    fi
}

# 查看训练状态
train_status() {
    print_header "训练状态"
    
    # 检查GPU服务器
    print_info "检查GPU服务器..."
    ssh $GPU_SERVER << 'EOF'
if [ -f ~/training.pid ]; then
    PID=$(cat ~/training.pid)
    if ps -p $PID > /dev/null 2>&1; then
        echo "✓ 训练进程运行中 (PID: $PID)"
        ps -p $PID -o pid,etime,pcpu,pmem,cmd
    else
        echo "✗ 训练进程未运行"
    fi
else
    echo "✗ 未找到训练PID文件"
fi

# 检查最新模型
if [ -d ~/workspace/btcquant/storage/models ]; then
    echo ""
    echo "最新模型:"
    ls -lht ~/workspace/btcquant/storage/models/ | head -5
fi
EOF
}

# 查看训练日志
train_logs() {
    print_header "训练日志"
    ssh $GPU_SERVER "tail -100 ~/workspace/btcquant/storage/logs/training.log"
}

# 停止训练
train_stop() {
    print_header "停止训练"
    ssh $GPU_SERVER << 'EOF'
if [ -f ~/training.pid ]; then
    PID=$(cat ~/training.pid)
    if ps -p $PID > /dev/null 2>&1; then
        kill $PID
        echo "✓ 训练进程已停止 (PID: $PID)"
    else
        echo "✗ 训练进程未运行"
    fi
    rm ~/training.pid
else
    echo "✗ 未找到训练PID文件"
fi
EOF
}

# 同步训练数据到GPU服务器
train_sync_data() {
    print_header "同步训练数据到GPU服务器"
    
    # 从CPU服务器传输到GPU服务器
    ssh $CPU_SERVER "scp /root/workspace/btcquant/training_data_cache.pkl $GPU_SERVER:~/workspace/btcquant/storage/cache/data_cache.pkl"
    
    # 验证文件
    ssh $GPU_SERVER "ls -lh ~/workspace/btcquant/storage/cache/data_cache.pkl"
    
    print_success "数据同步完成"
}

# 同步模型到CPU服务器
train_sync_model() {
    local model_dir=$1
    
    if [ -z "$model_dir" ]; then
        # 自动检测最新模型
        print_info "检测最新模型..."
        model_dir=$(ssh $GPU_SERVER "ls -t ~/workspace/btcquant/storage/models/ | grep tcn_ | head -1")
        if [ -z "$model_dir" ]; then
            print_error "未找到模型"
            exit 1
        fi
        print_info "找到模型: $model_dir"
    fi
    
    print_header "同步模型到CPU服务器"
    ssh $GPU_SERVER << EOF
scp -r ~/workspace/btcquant/storage/models/$model_dir $CPU_SERVER:$PROJECT_DIR/storage/models/
EOF
    print_success "模型同步完成: $model_dir"
}

# 同步配置文件到GPU服务器
train_sync_config() {
    print_header "同步配置文件到GPU服务器"
    
    if [ ! -f "config.yaml" ]; then
        print_error "配置文件不存在: config.yaml"
        print_info "请先复制并配置: cp config.yaml.example config.yaml"
        return 1
    fi
    
    scp config.yaml $GPU_SERVER:~/workspace/btcquant/
    print_success "配置文件同步完成"
}

# GPU训练命令（保留向后兼容）
cmd_gpu() {
    local action=$1
    
    case $action in
        setup)
            gpu_setup
            ;;
        train)
            train_start --gpu
            ;;
        sync-data)
            train_sync_data
            ;;
        sync-model)
            train_sync_model "$2"
            ;;
        *)
            print_error "未知GPU命令: $action"
            print_info "建议使用新命令: btcquant train <action>"
            exit 1
            ;;
    esac
}

# 初始化GPU环境
gpu_setup() {
    print_header "初始化GPU环境"
    ssh $GPU_SERVER << 'EOF'
set -e

# 安装git
if ! command -v git &> /dev/null; then
    echo "安装Git..."
    yum install -y git || apt-get install -y git
fi

# 安装Python 3.11（如果不存在）
if ! command -v python3.11 &> /dev/null; then
    echo "安装Python 3.11..."
    if command -v yum &> /dev/null; then
        yum install -y python3.11 python3.11-devel python3.11-pip
    elif command -v apt-get &> /dev/null; then
        apt-get update
        apt-get install -y python3.11 python3.11-venv python3.11-dev
    fi
fi

# 克隆或更新代码
if [ -d ~/workspace/btcquant ]; then
    echo "更新代码..."
    cd ~/workspace/btcquant
    git pull origin main
else
    echo "克隆代码..."
    mkdir -p ~/workspace
    cd ~/workspace
    git clone https://github.com/ningersweet/btcquant.git
    cd btcquant
fi

# 创建venv环境（使用Python 3.11）
if [ ! -d ~/workspace/btcquant/venv ]; then
    echo "创建Python 3.11虚拟环境..."
    cd ~/workspace/btcquant
    python3.11 -m venv venv
fi

# 激活环境并安装依赖
echo "安装依赖..."
cd ~/workspace/btcquant
source venv/bin/activate
pip install --upgrade pip

# 安装PyTorch GPU版本
echo "安装PyTorch GPU版本..."
pip install torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu118

# 安装项目依赖
echo "安装项目依赖..."
pip install -r predict/requirements.txt

# 创建存储目录
mkdir -p storage/logs storage/cache storage/models

# 验证GPU可用性
echo ""
echo "验证PyTorch GPU..."
python -c "import torch; print(f'PyTorch版本: {torch.__version__}'); print(f'CUDA可用: {torch.cuda.is_available()}'); print(f'GPU数量: {torch.cuda.device_count()}'); print(f'GPU名称: {torch.cuda.get_device_name(0) if torch.cuda.is_available() else "N/A"}')"

echo ""
echo "✓ GPU环境初始化完成"
echo ""
echo "下一步："
echo "1. 同步配置文件: btcquant train sync-config"
echo "2. 同步训练数据: btcquant train sync-data"
echo "3. 启动训练: btcquant train start --gpu"
EOF
    print_success "GPU环境初始化完成"
}

# 本地开发命令
cmd_local() {
    local action=$1
    
    case $action in
        train)
            local_train
            ;;
        test)
            local_test
            ;;
        lint)
            local_lint
            ;;
        *)
            print_error "未知本地命令: $action"
            exit 1
            ;;
    esac
}

# 本地训练
local_train() {
    print_header "本地快速训练"
    cd "$SCRIPT_DIR/predict"
    python train_fast.py
}

# 运行测试
local_test() {
    print_header "运行测试"
    cd "$SCRIPT_DIR"
    python -m pytest tests/
}

# 代码检查
local_lint() {
    print_header "代码检查"
    cd "$SCRIPT_DIR"
    flake8 . --exclude=venv,__pycache__
}

# Git命令
cmd_git() {
    local action=$1
    
    case $action in
        push)
            git_push
            ;;
        deploy)
            git_deploy $2
            ;;
        *)
            print_error "未知Git命令: $action"
            exit 1
            ;;
    esac
}

# 提交并推送代码
git_push() {
    print_header "提交并推送代码"
    cd "$SCRIPT_DIR"
    
    git add -A
    echo "请输入提交信息:"
    read commit_msg
    git commit -m "$commit_msg"
    git push origin main
    
    print_success "代码已推送"
}

# Git部署
git_deploy() {
    local target=$1
    if [ -f "$SCRIPT_DIR/git_deploy.sh" ]; then
        "$SCRIPT_DIR/git_deploy.sh" $target
    else
        print_error "git_deploy.sh 不存在"
        exit 1
    fi
}

# 修复并部署
cmd_fix() {
    local action=$1
    
    case $action in
        deploy)
            fix_deploy
            ;;
        *)
            print_error "未知修复命令: $action"
            exit 1
            ;;
    esac
}

# 修复并部署
fix_deploy() {
    if [ -f "$SCRIPT_DIR/fix_and_deploy.sh" ]; then
        "$SCRIPT_DIR/fix_and_deploy.sh"
    else
        print_error "fix_and_deploy.sh 不存在"
        exit 1
    fi
}

# 显示版本信息
show_version() {
    echo "BTC Quant v${VERSION}"
    echo "Git commit: $(git rev-parse --short HEAD 2>/dev/null || echo 'unknown')"
}

# 主函数
main() {
    if [ $# -eq 0 ]; then
        show_help
        exit 0
    fi
    
    local command=$1
    shift
    
    case $command in
        server)
            cmd_server "$@"
            ;;
        data)
            cmd_data "$@"
            ;;
        docker)
            cmd_docker "$@"
            ;;
        train)
            cmd_train "$@"
            ;;
        gpu)
            cmd_gpu "$@"
            ;;
        local)
            cmd_local "$@"
            ;;
        git)
            cmd_git "$@"
            ;;
        fix)
            cmd_fix "$@"
            ;;
        version)
            show_version
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            print_error "未知命令: $command"
            echo "使用 'btcquant help' 查看帮助"
            exit 1
            ;;
    esac
}

main "$@"

#!/bin/bash
# BTC Quant 统一命令行工具
# 整合所有脚本功能，通过子命令执行不同操作

set -e

VERSION="1.0.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# 服务器配置
CPU_SERVER="${CPU_SERVER:-root@47.236.94.252}"
GPU_SERVER="${GPU_SERVER:-gpu_server}"
CPU_SERVER_IP="47.236.94.252"
PROJECT_DIR="/root/workspace/btcquant"
GIT_REPO="https://github.com/ningersweet/btcquant.git"

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 打印函数
print_header() {
    echo -e "${BLUE}=========================================="
    echo -e "$1"
    echo -e "==========================================${NC}"
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

print_error() {
    echo -e "${RED}✗ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}⚠ $1${NC}"
}

print_info() {
    echo -e "${BLUE}ℹ $1${NC}"
}

# 显示帮助
show_help() {
    cat << EOF
BTC Quant 统一命令行工具 v${VERSION}

用法: btcquant <命令> [选项]

服务器管理:
  server init <cpu|gpu>          首次部署到服务器
  server update <cpu|gpu>        更新服务器代码
  server status <cpu|gpu>        查看服务器状态
  server shell <cpu|gpu>         SSH登录服务器
  server logs <cpu|gpu> [服务]   查看服务日志

数据服务:
  data start                     启动数据服务
  data stop                      停止数据服务
  data restart                   重启数据服务
  data status                    查看数据服务状态
  data prepare                   准备训练数据
  data sync                      同步历史数据

容器管理:
  docker build [服务]            构建Docker镜像
  docker up [服务]               启动容器
  docker down [服务]             停止容器
  docker ps                      查看容器状态
  docker logs [服务]             查看容器日志
  docker monitor                 监控容器资源

训练管理:
  train start [--gpu]            启动训练（默认CPU，--gpu使用GPU）
  train status                   查看训练状态
  train logs                     查看训练日志
  train stop                     停止训练
  train sync-data                同步训练数据到GPU服务器
  train sync-model               同步模型到CPU服务器
  train sync-config              同步配置文件到GPU服务器

本地开发:
  local train                    本地训练（快速模式）
  local test                     运行测试
  local lint                     代码检查

工具:
  git push                       提交并推送代码
  git deploy <cpu|gpu>           Git部署到服务器
  fix deploy                     修复并部署
  version                        显示版本信息
  help                           显示此帮助信息

示例:
  btcquant server init cpu       # 首次部署到CPU服务器
  btcquant data prepare          # 准备训练数据
  btcquant train start --gpu     # 启动GPU训练
  btcquant train logs            # 查看训练日志
  btcquant docker monitor        # 监控容器资源
  btcquant server logs cpu data-service  # 查看数据服务日志

EOF
}

# 服务器管理命令
cmd_server() {
    local action=$1
    local target=$2
    
    case $action in
        init)
            server_init $target
            ;;
        update)
            server_update $target
            ;;
        status)
            server_status $target
            ;;
        shell)
            server_shell $target
            ;;
        logs)
            server_logs $target $3
            ;;
        *)
            print_error "未知服务器命令: $action"
            echo "使用 'btcquant help' 查看帮助"
            exit 1
            ;;
    esac
}

# 首次部署到服务器
server_init() {
    local target=$1
    local server=""
    
    case $target in
        cpu)
            server=$CPU_SERVER
            ;;
        gpu)
            server=$GPU_SERVER
            ;;
        *)
            print_error "请指定服务器: cpu 或 gpu"
            exit 1
            ;;
    esac
    
    print_header "首次部署到 $target 服务器"
    
    ssh $server << EOF
set -e

if [ -d $PROJECT_DIR ]; then
    echo "项目目录已存在，更新代码..."
    cd $PROJECT_DIR
    git pull origin main
else
    echo "克隆项目..."
    mkdir -p /root/workspace
    cd /root/workspace
    git clone $GIT_REPO btcquant
    cd btcquant
fi

# 设置执行权限
chmod +x *.sh 2>/dev/null || true

# 复制配置文件
if [ ! -f config.yaml ]; then
    cp config.yaml.example config.yaml
fi

if [ ! -f .env ]; then
    cp .env.example .env
fi

echo ""
echo "当前版本:"
git log -1 --oneline
EOF
    
    print_success "部署完成"
}

# 更新服务器代码
server_update() {
    local target=$1
    local server=""
    
    case $target in
        cpu)
            server=$CPU_SERVER
            ;;
        gpu)
            server=$GPU_SERVER
            ;;
        *)
            print_error "请指定服务器: cpu 或 gpu"
            exit 1
            ;;
    esac
    
    print_header "更新 $target 服务器代码"
    
    ssh $server << EOF
set -e
cd $PROJECT_DIR
git pull origin main
echo ""
echo "当前版本:"
git log -1 --oneline
EOF
    
    print_success "代码已更新"
}

# 查看服务器状态
server_status() {
    local target=$1
    local server=""
    
    case $target in
        cpu)
            server=$CPU_SERVER
            ;;
        gpu)
            server=$GPU_SERVER
            ;;
        *)
            print_error "请指定服务器: cpu 或 gpu"
            exit 1
            ;;
    esac
    
    print_header "$target 服务器状态"
    
    ssh $server << 'EOF'
cd /root/workspace/btcquant

echo "Docker容器:"
docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"

echo ""
echo "磁盘使用:"

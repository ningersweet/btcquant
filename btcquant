# SSH登录服务器
server_shell() {
    local target=$1
    local server=""
    
    case $target in
        cpu)
            server=$CPU_SERVER
            ;;
        gpu)
            server=$GPU_SERVER
            ;;
        *)
            print_error "请指定服务器: cpu 或 gpu"
            exit 1
            ;;
    esac
    
    print_info "登录到 $target 服务器..."
    ssh $server
}

# 查看服务器日志
server_logs() {
    local target=$1
    local service=${2:-data-service}
    local server=""
    
    case $target in
        cpu)
            server=$CPU_SERVER
            ;;
        gpu)
            server=$GPU_SERVER
            ;;
        *)
            print_error "请指定服务器: cpu 或 gpu"
            exit 1
            ;;
    esac
    
    print_info "查看 $target 服务器 $service 日志..."
    ssh $server "cd $PROJECT_DIR && docker logs --tail 50 -f btc_quant_$service"
}

# 数据服务命令
cmd_data() {
    local action=$1
    
    case $action in
        start)
            data_start
            ;;
        stop)
            data_stop
            ;;
        restart)
            data_restart
            ;;
        status)
            data_status
            ;;
        prepare)
            data_prepare
            ;;
        sync)
            data_sync
            ;;
        *)
            print_error "未知数据命令: $action"
            exit 1
            ;;
    esac
}

# 启动数据服务
data_start() {
    print_header "启动数据服务"
    ssh $CPU_SERVER << EOF
cd $PROJECT_DIR
docker-compose up -d data-service
sleep 5
docker ps --filter "name=data-service"
EOF
    print_success "数据服务已启动"
}

# 停止数据服务
data_stop() {
    print_header "停止数据服务"
    ssh $CPU_SERVER << EOF
cd $PROJECT_DIR
docker-compose stop data-service
EOF
    print_success "数据服务已停止"
}

# 重启数据服务
data_restart() {
    print_header "重启数据服务"
    ssh $CPU_SERVER << EOF
cd $PROJECT_DIR
docker-compose restart data-service
sleep 5
docker ps --filter "name=data-service"
EOF
    print_success "数据服务已重启"
}

# 查看数据服务状态
data_status() {
    print_header "数据服务状态"
    ssh $CPU_SERVER << 'EOF'
cd /root/workspace/btcquant
echo "容器状态:"
docker ps --filter "name=data-service"
echo ""
echo "资源使用:"
docker stats --no-stream btc_quant_data_service
echo ""
echo "数据库状态:"
curl -s http://localhost:8001/api/v1/status?symbol=BTCUSDT\&interval=5m | python3 -m json.tool
EOF
}

# 准备训练数据
data_prepare() {
    print_header "准备训练数据"
    ssh $CPU_SERVER << EOF
cd $PROJECT_DIR
./prepare_training_data.sh
EOF
}

# 同步历史数据
data_sync() {
    print_header "同步历史数据"
    print_warning "此操作将从Binance获取大量历史数据，可能需要较长时间"
    read -p "确认继续? (y/n) " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        ssh $CPU_SERVER << EOF
cd $PROJECT_DIR
./prepare_training_data.sh

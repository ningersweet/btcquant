# TCN模型训练超参数配置
# 注意：这些参数属于敏感信息，不应提交到git

# ===== 标签生成参数 =====
# 入场缓冲系数 (0.15%)
LABEL_ALPHA=0.0015
# 止盈缓冲系数 (0.40%)
LABEL_GAMMA=0.0040
# 止损缓冲系数 (0.25%)
LABEL_BETA=0.0025
# 最小净利阈值 (1.00%)
LABEL_THETA_MIN=0.0100
# 预测窗口长度 (12根K线 = 1小时)
LABEL_K=12

# ===== 数据参数 =====
# 输入窗口长度 (288根5分钟K线 = 24小时)
DATA_WINDOW_SIZE=288
# K线间隔
DATA_INTERVAL=5m
# 训练数据起始日期
DATA_START_DATE=2019-01-01
# 训练数据结束日期 (留空则使用当前日期)
DATA_END_DATE=
# 训练集比例
DATA_TRAIN_RATIO=0.7
# 验证集比例
DATA_VAL_RATIO=0.15
# 测试集比例 (剩余部分)
DATA_TEST_RATIO=0.15

# ===== TCN模型架构参数 =====
# 输入特征维度
MODEL_INPUT_DIM=5
# TCN通道数
MODEL_CHANNELS=64
# TCN层数
MODEL_NUM_LAYERS=8
# 卷积核大小
MODEL_KERNEL_SIZE=3
# Dropout率
MODEL_DROPOUT=0.2

# ===== 训练参数 =====
# 批次大小
TRAIN_BATCH_SIZE=128
# 学习率
TRAIN_LEARNING_RATE=0.001
# 训练轮数
TRAIN_EPOCHS=100
# 早停耐心值
TRAIN_EARLY_STOPPING_PATIENCE=15
# 分类损失权重
TRAIN_LAMBDA_CLS=1.0
# 回归损失权重
TRAIN_LAMBDA_REG=0.5
# 设备 (cpu/cuda)
TRAIN_DEVICE=cpu

# ===== 推理参数 =====
# 最小置信度阈值
INFERENCE_MIN_CONFIDENCE=0.65
# 最小空间阈值
INFERENCE_MIN_SPACE=0.01

# ===== 服务配置 =====
DATA_SERVICE_URL=http://localhost:8001
FEATURES_SERVICE_URL=http://localhost:8002

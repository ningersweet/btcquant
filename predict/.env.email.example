# 邮件通知配置
# 将此文件复制为 .env.email 并填入真实信息

# SMTP服务器配置
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true

# 发件人邮箱（通常与SMTP_USER相同）
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# 收件人邮箱
FROM_EMAIL=your_email@gmail.com
TO_EMAIL=your_email@gmail.com

# 常见邮箱SMTP配置参考：
#
# Gmail:
#   SMTP_SERVER=smtp.gmail.com
#   SMTP_PORT=587
#   注意：需要开启"应用专用密码"
#
# QQ邮箱:
#   SMTP_SERVER=smtp.qq.com
#   SMTP_PORT=587
#   注意：需要开启SMTP服务并获取授权码
#
# 163邮箱:
#   SMTP_SERVER=smtp.163.com
#   SMTP_PORT=465
#   SMTP_USE_TLS=false
#   注意：需要开启SMTP服务并获取授权码
#
# Outlook:
#   SMTP_SERVER=smtp-mail.outlook.com
#   SMTP_PORT=587
